{
  "name": "kenikool-ui",
  "version": "0.1.0",
  "description": "Zero-config, theme-aware UI component library for Vanilla JS and React",
  "license": "MIT",
  "author": "Kenikool UI Contributors",
  "keywords": [
    "ui",
    "components",
    "react",
    "vanilla",
    "theme",
    "design-system"
  ],
  "main": "./dist/react/index.cjs",
  "module": "./dist/react/index.mjs",
  "types": "./dist/react/index.d.ts",
  "exports": {
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.mjs",
      "require": "./dist/react/index.cjs"
    },
    "./vanilla": {
      "types": "./dist/vanilla/index.d.ts",
      "import": "./dist/vanilla/index.mjs",
      "require": "./dist/vanilla/index.cjs"
    },
    "./themes": {
      "types": "./dist/themes/index.d.ts",
      "import": "./dist/themes/index.mjs",
      "require": "./dist/themes/index.cjs"
    },
    "./styles": "./dist/styles/base.css",
    "./styles/light": "./dist/styles/tokens/light.css",
    "./styles/dark": "./dist/styles/tokens/dark.css",
    "./styles/dracula": "./dist/styles/tokens/dracula.css"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": [
    "**/*.css",
    "src/**/*.ts",
    "src/**/*.tsx",
    "dist/vanilla/index.mjs",
    "dist/vanilla/index.cjs"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "smoke": "pnpm build && node scripts/smoke-install.mjs && pnpm smoke:serve",
    "smoke:refresh": "node scripts/smoke-install.mjs",
    "smoke:serve": "pnpm exec vite __smoke --port 5174 --open"
  },
  "peerDependencies": {
    "react": ">=19.0.0",
    "react-dom": ">=19.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  },
  "dependencies": {
    "dompurify": "^3.2.6"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.0",
    "@eslint/js": "^9.0.0",
    "@storybook/addon-essentials": "^8.6.14",
    "@storybook/addon-themes": "^10.4.4",
    "@storybook/react-vite": "^10.4.4",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.5.0",
    "@types/dompurify": "^3.0.5",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "eslint": "^9.0.0",
    "fast-check": "^4.7.0",
    "jsdom": "^26.0.0",
    "playwright": "^1.61.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "storybook": "^10.4.4",
    "svgo": "^4.0.1",
    "tsup": "^8.5.0",
    "typescript": "^6.0.0",
    "typescript-eslint": "^8.0.0",
    "vite": "^8.0.0",
    "vitest": "^4.1.0"
  },
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=11.0.0"
  }
}
